font-family = Iosevka
font-feature = -calt
font-feature = -liga
font-feature = -dlig
font-size = 18

theme = Catppuccin Mocha
background-opacity = 0.95
background-blur = true
shell-integration-features = ssh-env
macos-icon=holographic
macos-non-native-fullscreen=padded-notch

# for macos change alt to cmd
keybind = alt+digit_1=text:\x011
keybind = alt+digit_2=text:\x012
keybind = alt+digit_3=text:\x013
keybind = alt+digit_4=text:\x014
keybind = alt+digit_5=text:\x015
keybind = alt+digit_6=text:\x016
keybind = alt+digit_7=text:\x017
keybind = alt+digit_8=text:\x018
keybind = alt+digit_9=text:\x019
